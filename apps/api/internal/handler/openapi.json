{
  "openapi": "3.1.0",
  "info": {
    "title": "여행 공유 API",
    "version": "2.0.0",
    "description": "여행 공유 앱 백엔드 API"
  },
  "servers": [
    { "url": "http://localhost:8080", "description": "로컬 개발" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "example": "user@example.com" },
          "password": { "type": "string", "minLength": 8, "example": "password123" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "example": "user@example.com" },
          "password": { "type": "string", "example": "password123" }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "accessToken": { "type": "string" },
          "user": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "email": { "type": "string" }
            }
          }
        }
      },
      "AuthSessionResponse": {
        "type": "object",
        "properties": {
          "user": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "email": { "type": "string" }
            }
          }
        }
      },
      "TripResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "ownerId": { "type": "string" },
          "title": { "type": "string" },
          "startDate": { "type": "string", "example": "2026-06-27" },
          "endDate": { "type": "string", "example": "2026-06-30" },
          "travelers": { "type": "array", "items": { "type": "string" } },
          "memo": { "type": "string" }
        }
      },
      "PublicTripResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "startDate": { "type": "string", "example": "2026-06-27" },
          "endDate": { "type": "string", "example": "2026-06-30" },
          "travelers": { "type": "array", "items": { "type": "string" } }
        }
      },
      "CreateTripRequest": {
        "type": "object",
        "required": ["title", "startDate", "endDate"],
        "properties": {
          "title": { "type": "string", "example": "나의 여행" },
          "startDate": { "type": "string", "example": "2026-06-27" },
          "endDate": { "type": "string", "example": "2026-06-30" },
          "travelers": { "type": "array", "items": { "type": "string" }, "example": ["여행자 1", "여행자 2"] },
          "memo": { "type": "string" }
        }
      },
      "UpdateTripRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "startDate": { "type": "string" },
          "endDate": { "type": "string" },
          "travelers": { "type": "array", "items": { "type": "string" } },
          "memo": { "type": "string" }
        }
      },
      "CreateScheduleRequest": {
        "type": "object",
        "required": ["date", "time", "type", "title"],
        "properties": {
          "placeId": { "type": "string" },
          "date": { "type": "string", "example": "2026-06-27" },
          "time": { "type": "string", "example": "10:30" },
          "type": { "type": "string", "example": "sightseeing" },
          "title": { "type": "string", "example": "전망대 방문" },
          "transportMemo": { "type": "string" },
          "guideMemo": { "type": "string" }
        }
      },
      "ScheduleResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "placeId": { "type": "string" },
          "date": { "type": "string" },
          "time": { "type": "string" },
          "type": { "type": "string" },
          "title": { "type": "string" },
          "transportMemo": { "type": "string" },
          "guideMemo": { "type": "string" }
        }
      },
      "CreatePlaceRequest": {
        "type": "object",
        "required": ["name", "category"],
        "properties": {
          "name": { "type": "string", "example": "공항 렌터카 센터" },
          "category": { "type": "string", "example": "transport" },
          "address": { "type": "string", "example": "공항 1층" },
          "googleMapsUrl": { "type": "string", "example": "https://www.google.com/maps/search/?api=1&query=airport" },
          "recommendedReason": { "type": "string", "example": "도착 후 바로 이동할 장소" }
        }
      },
      "CreateFlightRequest": {
        "type": "object",
        "required": ["direction", "label", "departureAirport", "arrivalAirport", "departureDate", "departureTime"],
        "properties": {
          "direction": { "type": "string", "example": "departure" },
          "label": { "type": "string", "example": "출국 항공편" },
          "airline": { "type": "string", "example": "대한항공" },
          "flightNumber": { "type": "string", "example": "KE123" },
          "departureAirport": { "type": "string", "example": "인천" },
          "arrivalAirport": { "type": "string", "example": "도쿄" },
          "departureDate": { "type": "string", "example": "2026-07-10" },
          "departureTime": { "type": "string", "example": "10:30" },
          "arrivalDate": { "type": "string", "example": "2026-07-10" },
          "arrivalTime": { "type": "string", "example": "12:45" },
          "memo": { "type": "string", "example": "터미널 확인 필요" }
        }
      },
      "PlaceResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "category": { "type": "string" },
          "address": { "type": "string" },
          "googleMapsUrl": { "type": "string" },
          "recommendedReason": { "type": "string" }
        }
      },
      "FlightResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "direction": { "type": "string" },
          "label": { "type": "string" },
          "airline": { "type": "string" },
          "flightNumber": { "type": "string" },
          "departureAirport": { "type": "string" },
          "arrivalAirport": { "type": "string" },
          "departureDate": { "type": "string" },
          "departureTime": { "type": "string" },
          "arrivalDate": { "type": "string" },
          "arrivalTime": { "type": "string" },
          "memo": { "type": "string" }
        }
      },
      "ShareLinkResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "apiPath": { "type": "string", "example": "/api/share/share-token" },
          "webPath": { "type": "string", "example": "/share/share-token" },
          "expiresAt": { "type": "string" }
        }
      },
      "SharedTripResponse": {
        "type": "object",
        "properties": {
          "trip": { "$ref": "#/components/schemas/PublicTripResponse" },
          "schedules": { "type": "array", "items": { "type": "object" } },
          "places": { "type": "array", "items": { "type": "object" } },
          "flights": { "type": "array", "items": { "$ref": "#/components/schemas/FlightResponse" } },
          "routes": { "type": "array", "items": { "type": "object" } }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/healthz": {
      "get": {
        "summary": "서버 상태 확인",
        "tags": ["헬스"],
        "responses": {
          "200": { "description": "정상" }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "회원가입",
        "tags": ["인증"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RegisterRequest" } } }
        },
        "responses": {
          "201": { "description": "가입 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "400": { "description": "입력 오류", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "409": { "description": "이미 사용 중인 이메일", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "로그인",
        "tags": ["인증"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LoginRequest" } } }
        },
        "responses": {
          "200": { "description": "로그인 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "401": { "description": "인증 실패", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "summary": "현재 로그인 사용자 확인",
        "tags": ["인증"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "현재 사용자", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthSessionResponse" } } } },
          "401": { "description": "인증 필요", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/trips": {
      "get": {
        "summary": "내 여행 목록",
        "tags": ["여행"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "성공", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/TripResponse" } } } } },
          "401": { "description": "인증 필요" }
        }
      },
      "post": {
        "summary": "여행 생성",
        "tags": ["여행"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateTripRequest" } } }
        },
        "responses": {
          "201": { "description": "생성 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TripResponse" } } } },
          "400": { "description": "입력 오류" },
          "401": { "description": "인증 필요" }
        }
      }
    },
    "/api/trips/{tripID}": {
      "parameters": [
        { "name": "tripID", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "summary": "여행 상세 조회",
        "tags": ["여행"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TripResponse" } } } },
          "404": { "description": "없음" }
        }
      },
      "patch": {
        "summary": "여행 수정",
        "tags": ["여행"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateTripRequest" } } }
        },
        "responses": {
          "200": { "description": "수정 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TripResponse" } } } },
          "403": { "description": "권한 없음" },
          "404": { "description": "없음" }
        }
      },
      "delete": {
        "summary": "여행 삭제",
        "tags": ["여행"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "204": { "description": "삭제 성공" },
          "403": { "description": "권한 없음" },
          "404": { "description": "없음" }
        }
      }
    },
    "/api/trips/{tripID}/share": {
      "parameters": [
        { "name": "tripID", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "post": {
        "summary": "가족 공유 링크 생성",
        "tags": ["공유"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "공유 링크 생성 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ShareLinkResponse" } } } },
          "403": { "description": "권한 없음" },
          "404": { "description": "여행 없음" }
        }
      }
    },
    "/api/share/{token}": {
      "parameters": [
        { "name": "token", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "summary": "공유 링크로 여행 읽기 전용 조회",
        "tags": ["공유"],
        "responses": {
          "200": { "description": "성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SharedTripResponse" } } } },
          "404": { "description": "공유 링크 없음" }
        }
      }
    },
    "/api/trips/{tripID}/schedules": {
      "parameters": [
        { "name": "tripID", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "summary": "일정 목록",
        "tags": ["일정"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "성공" } }
      },
      "post": {
        "summary": "일정 생성",
        "tags": ["일정"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateScheduleRequest" } } }
        },
        "responses": {
          "201": { "description": "일정 생성 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ScheduleResponse" } } } },
          "400": { "description": "입력 오류" },
          "403": { "description": "권한 없음" },
          "404": { "description": "여행 없음" }
        }
      }
    },
    "/api/trips/{tripID}/schedules/{scheduleID}": {
      "parameters": [
        { "name": "tripID", "in": "path", "required": true, "schema": { "type": "string" } },
        { "name": "scheduleID", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "delete": {
        "summary": "일정 삭제",
        "tags": ["일정"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "204": { "description": "일정 삭제 성공" },
          "403": { "description": "권한 없음" },
          "404": { "description": "여행 또는 일정 없음" }
        }
      }
    },
    "/api/trips/{tripID}/places": {
      "parameters": [
        { "name": "tripID", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "summary": "장소 목록",
        "tags": ["장소"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "성공" } }
      },
      "post": {
        "summary": "장소 생성",
        "tags": ["장소"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreatePlaceRequest" } } }
        },
        "responses": {
          "201": { "description": "장소 생성 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PlaceResponse" } } } },
          "400": { "description": "입력 오류" },
          "403": { "description": "권한 없음" },
          "404": { "description": "여행 없음" }
        }
      }
    },
    "/api/trips/{tripID}/places/{placeID}": {
      "parameters": [
        { "name": "tripID", "in": "path", "required": true, "schema": { "type": "string" } },
        { "name": "placeID", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "delete": {
        "summary": "장소 삭제",
        "tags": ["장소"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "204": { "description": "장소 삭제 성공" },
          "403": { "description": "권한 없음" },
          "404": { "description": "여행 또는 장소 없음" }
        }
      }
    },
    "/api/trips/{tripID}/routes": {
      "parameters": [
        { "name": "tripID", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "summary": "추천 루트 목록",
        "tags": ["루트"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "성공" } }
      }
    },
    "/api/trips/{tripID}/flights": {
      "parameters": [
        { "name": "tripID", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "summary": "항공편 목록",
        "tags": ["항공"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "성공", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/FlightResponse" } } } } },
          "403": { "description": "권한 없음" },
          "404": { "description": "여행 없음" }
        }
      },
      "post": {
        "summary": "항공편 생성",
        "tags": ["항공"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateFlightRequest" } } }
        },
        "responses": {
          "201": { "description": "항공편 생성 성공", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FlightResponse" } } } },
          "400": { "description": "입력 오류" },
          "403": { "description": "권한 없음" },
          "404": { "description": "여행 없음" }
        }
      }
    }
  }
}
